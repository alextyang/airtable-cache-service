{
  "name": "airtable",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare:preloads": "node scripts/prepare-preloads.mjs",
    "dev": "node scripts/run-next-with-preloads.mjs dev",
    "build": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next build",
    "start": "node scripts/run-next-with-preloads.mjs start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run tests/airtable-cache tests/routes tests/zapier",
    "test:coverage": "vitest run --coverage tests/airtable-cache tests/routes tests/zapier",
    "test:regression": "npm run build && vitest run tests/regression/preload-static-startup.regression.test.ts && vitest run tests/regression/airtable-service.regression.test.ts",
    "check": "npm run lint && npm run typecheck && npm run test && npm run test:regression"
  },
  "dependencies": {
    "next": "^15.5.7",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
